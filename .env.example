# Copy this file to .env.local and fill in values from:
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
# Server-only teacher bootstrap email (preferred over NEXT_PUBLIC_ADMIN_EMAIL)
ADMIN_EMAIL=your-teacher-email@example.com

# Legacy fallback — prefer ADMIN_EMAIL above (not exposed to browser)
NEXT_PUBLIC_ADMIN_EMAIL=your-teacher-email@example.com

# REQUIRED for student sign-up emails and password reset
NEXT_PUBLIC_SITE_URL=https://my-first-tigrigna-website.vercel.app

# Required for in-app notifications, student import, and login-help emails
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email notifications when teachers publish lessons, homework, or announcements
# Also run supabase/FIX_NOTIFICATIONS.sql in Supabase SQL Editor for in-app bell alerts
# Sign up at https://resend.com — verify your domain for production sends
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Tigrigna Learning Portal <notifications@yourdomain.com>
